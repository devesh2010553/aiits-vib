# ── Required ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aiits
ADMIN_EMAIL=your_admin@gmail.com
ADMIN_PASSWORD=your_secure_admin_password_here
JWT_SECRET=paste_a_very_long_random_string_here_at_least_64_characters_long

# ── Email (Gmail App Password — NOT your regular password) ────────────────
# STEPS:
# 1. myaccount.google.com → Security → Turn ON 2-Step Verification
# 2. myaccount.google.com/apppasswords
# 3. Click "Create app password" → name it "AIITS" → click Create
# 4. Copy the 16-character code (no spaces) and paste below
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (for result archiving) ─────────────────────────────────
# STEPS:
# 1. Go to console.cloud.google.com → New project "AIITS"
# 2. Enable APIs: Google Sheets API, Google Drive API
# 3. Create credentials → Service Account → download JSON key
# 4. Share your Google Sheet with the service account email (Editor access)
# 5. EITHER: paste credentials.json file in project root
#    OR: copy entire JSON content and paste as GOOGLE_CREDENTIALS_JSON below
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Optional ───────────────────────────────────────────────────────────────
OTP_EXPIRY=10
NODE_ENV=production
PORT=3000
CLIENT_URL=https://aiits-msc.onrender.com

# ── Push Notifications (optional) ─────────────────────────────────────────
# Generate VAPID keys: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
