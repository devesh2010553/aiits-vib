# ── Required ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aiits
ADMIN_EMAIL=your_admin@gmail.com
ADMIN_PASSWORD=your_secure_admin_password_here
JWT_SECRET=paste_a_very_long_random_string_here_at_least_64_characters_long

# ── Firebase (replaces EMAIL_USER / EMAIL_PASS / OTP logic) ─────────────────
# STEPS:
# 1. Go to https://console.firebase.google.com → your project
# 2. Project settings → Service accounts → Generate new private key
# 3. Copy the ENTIRE JSON content and paste below (all on one line)
# 4. Also paste the firebaseConfig into frontend/index.html (search for YOUR_FIREBASE_API_KEY)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Sheets (unchanged) ────────────────────────────────────────────────
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Optional ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CLIENT_URL=https://msc.aiits.workers.dev

# ── Push Notifications (optional) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# REMOVED (no longer needed — Firebase handles email):
# EMAIL_USER
# EMAIL_PASS
# OTP_EXPIRY
